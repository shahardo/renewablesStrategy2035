<nav class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <i class="ti ti-solar-panel" style="color:#639922"></i>
    <span>אנרגיות 2035</span>
  </div>

  <a href="/" class="sidebar-item<%= activePage === 'dashboard' ? ' active' : '' %>">
    <div class="sidebar-ico sidebar-ico-home">
      <i class="ti ti-layout-dashboard"></i>
    </div>
    <span>מבט כולל</span>
  </a>

  <div class="sidebar-sep"></div>

  <% sidebarItems.forEach(item => { %>
  <a href="/initiative/<%= item.id %>" class="sidebar-item<%= activePage === item.id ? ' active' : '' %>">
    <div class="sidebar-ico" style="background:<%= item.iconBg %>">
      <i class="ti <%= item.icon %>" style="color:<%= item.iconColor %>"></i>
    </div>
    <div class="sidebar-body">
      <span class="sidebar-title"><%- item.title %></span>
      <div class="sidebar-prog">
        <div class="sidebar-track">
          <div class="sidebar-fill" style="width:<%= item.avgPct %>%;background:<%= item.color %>"></div>
        </div>
        <span class="sidebar-stat"><%= item.done %>/<%= item.total %></span>
      </div>
    </div>
  </a>
  <% }) %>
</nav>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
