<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>לוח מעקב — אנרגיות מתחדשות 2035</title>
  <link rel="stylesheet" href="/dashboard-styles.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
</head>
<body>

<button class="sidebar-toggle" id="sidebarToggle" aria-label="פתח תפריט">
  <i class="ti ti-menu-2"></i>
</button>

<div class="layout">
  <%- include('partials/sidebar') %>

  <main class="main-content">
    <div class="db">
      <h2 class="sr-only">לוח מעקב יישום תוכנית אנרגיות מתחדשות 2035 — KPIs ומדדי התקדמות לפי 6 מהלכי-על</h2>

      <div class="kgrid">
        <% kpis.forEach(kpi => { %>
        <div class="kcard">
          <div class="klabel"><%- kpi.label %></div>
          <div class="kval"><%- kpi.value %></div>
          <div class="ksub"><%- kpi.sub %></div>
          <% if (kpi.progress != null) { %>
          <div class="kpbar"><div class="kpfill" style="width:<%= kpi.progress %>%;background:<%= kpi.color %>"></div></div>
          <% } %>
        </div>
        <% }) %>
      </div>

      <div class="chart-grid">
        <div class="chart-panel">
          <div class="sec-hdr">מפת הדרכים: עבר ← הווה ← עתיד (2015–2035)</div>
          <canvas id="trajectoryChart"></canvas>
        </div>
        <div class="chart-panel">
          <div class="sec-hdr">קיבולת שנתית מותקנת לפי סוג (GW)</div>
          <canvas id="capacityChart"></canvas>
        </div>
      </div>

      <div class="cap-layout">
        <div class="panel">
          <div class="sec-hdr">מסלול קיבולת לעמידה ביעד 26 GW ב-2035</div>

          <% capacityTracks.forEach(track => { %>
          <div class="caprow">
            <div class="caplabel"><%- track.label %></div>
            <div class="captrack">
              <% track.fills.forEach(fill => { %>
              <div class="capfill" style="left:<%= fill.left %>%;width:<%= fill.width %>%;background:<%= fill.color %>"></div>
              <% }) %>
              <div class="captarget" style="left:<%= track.target %>%"></div>
            </div>
            <div class="capval"><%- track.capval %></div>
          </div>
          <% }) %>

          <div class="leg">
            <div class="legitem"><div class="legsq" style="background:#639922"></div>מותקן</div>
            <div class="legitem"><div class="legsq" style="background:#9FE1CB"></div>בהקמה</div>
            <div class="legitem"><div class="legsq" style="background:var(--color-background-secondary)"></div>נדרש נוסף</div>
            <div class="legitem"><div class="leg-target"></div>יעד 2035</div>
          </div>
        </div>

        <div class="chart-panel">
          <div class="sec-hdr">קיבולת מותקנת ומתוכננת לפי סוג ושנה (GW)</div>
          <canvas id="detailCapacityChart"></canvas>
        </div>
      </div>

      <div class="sec-hdr">6 מהלכי-על — לחץ לפרטים ולמעקב מעמיק</div>
      <div class="igrid">
        <% const dotColors = { done: '#639922', progress: '#378ADD', early: '#BA7517', none: 'var(--color-border-tertiary)' }; %>
        <% initiatives.forEach(init => { %>
        <a class="icard" href="/initiative/<%= init.id %>">
          <div class="ihead">
            <div class="iico" style="background:<%= init.iconBg %>">
              <i class="ti <%= init.icon %>" style="color:<%= init.iconColor %>" aria-hidden="true"></i>
            </div>
            <div class="ititle"><%- init.title %></div>
          </div>
          <div class="isub"><%- init.subtitle %></div>
          <% if (init.type === 'gw') { %>
          <div class="igw"><%- init.gwCurrent %> <span>/ <%- init.gwTarget %> GW</span></div>
          <% } else { %>
          <div class="icard-infra">תשתית מאפשרת</div>
          <% } %>
          <div class="icard-pbar">
            <div class="icard-ptrack">
              <div class="icard-pfill" style="width:<%= init.avgPct %>%;background:<%= init.color %>"></div>
            </div>
            <div class="icard-pval"><%= init.avgPct %>%</div>
          </div>
          <div class="icard-dots">
            <% init.actions.forEach(action => { %>
            <div class="icard-dot" style="background:<%= dotColors[action.status] %>"></div>
            <% }) %>
          </div>
          <div class="icard-count"><%= init.actions.length %> צעדי מדיניות</div>
        </a>
        <% }) %>
      </div>

    </div>
  </main>
</div>

<script>
(function () {
  const dark      = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const textColor = dark ? '#a8a7a2' : '#5f5e5a';
  const mutedColor= dark ? '#6a6966' : '#9d9c98';
  const gridColor = dark ? 'rgba(240,239,233,0.07)' : 'rgba(26,26,24,0.05)';

  const cd = <%- JSON.stringify(charts) %>;

  const baseScales = {
    x: { ticks: { color: textColor, font: { size: 10 } }, grid: { color: gridColor } },
    y: { ticks: { color: textColor, font: { size: 10 } }, grid: { color: gridColor }, beginAtZero: true }
  };
  const baseLegend = { rtl: true, position: 'bottom', labels: { color: textColor, font: { size: 11 }, boxWidth: 18, padding: 10 } };

  /* ── Trajectory chart ──────────────────────────── */
  const currentIdx = cd.trajectory.years.indexOf(cd.trajectory.currentYear);

  new Chart(document.getElementById('trajectoryChart'), {
    type: 'line',
    data: {
      labels: cd.trajectory.years,
      datasets: [
        {
          label: 'מגמה היסטורית',
          data: cd.trajectory.historical,
          borderColor: '#4A90D9',
          backgroundColor: 'rgba(74,144,217,0.08)',
          borderWidth: 2.5,
          pointRadius: (ctx) => ctx.dataIndex === currentIdx ? 6 : 2,
          pointBackgroundColor: '#4A90D9',
          fill: true, tension: 0.4, spanGaps: false,
        },
        {
          label: `תוכנית מואצת (${cd.trajectory.targetEnd}%)`,
          data: cd.trajectory.target,
          borderColor: '#639922',
          backgroundColor: 'rgba(99,153,34,0.07)',
          borderWidth: 2,
          pointRadius: (ctx) => ctx.dataIndex === cd.trajectory.years.length - 1 ? 5 : 0,
          pointBackgroundColor: '#639922',
          fill: true, tension: 0.35, spanGaps: false,
        },
        {
          label: `המשך המגמה הנוכחית (${cd.trajectory.trendEnd}%)`,
          data: cd.trajectory.trend,
          borderColor: '#D85A30',
          borderDash: [6, 4],
          borderWidth: 2,
          pointRadius: (ctx) => ctx.dataIndex === cd.trajectory.years.length - 1 ? 5 : 0,
          pointBackgroundColor: '#D85A30',
          fill: false, tension: 0.3, spanGaps: false,
        },
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: { ...baseLegend },
        tooltip: { rtl: true, callbacks: { label: (c) => ` ${c.dataset.label}: ${c.parsed.y}%` } },
      },
      scales: {
        x: { ...baseScales.x },
        y: {
          ...baseScales.y,
          max: 50,
          ticks: { ...baseScales.y.ticks, callback: (v) => v + '%' },
        },
      },
    },
  });

  /* ── Annual capacity chart ─────────────────────── */
  const ac = cd.annualCapacity;
  const flatLine = (val) => ac.years.map((_, i) => (i >= currentIdx ? val : null));

  // Plugin: draws rate labels directly on the chart near the right end of each line
  const inlineRateLabels = {
    id: 'inlineRateLabels',
    afterDatasetsDraw(chart) {
      const { ctx, chartArea, scales } = chart;
      if (!chartArea) return;
      const lines = [
        { value: ac.currentRate,  text: `${ac.currentRate} GW/שנה — קצב נוכחי`,  color: mutedColor,  dy: -5 },
        { value: ac.requiredRate, text: `${ac.requiredRate} GW/שנה — קצב נדרש`, color: '#D85A30', dy: -5 },
      ];
      ctx.save();
      ctx.font = 'bold 9.5px Heebo, Arial, sans-serif';
      ctx.textAlign = 'left';
      for (const { value, text, color, dy } of lines) {
        const y = scales.y.getPixelForValue(value);
        if (y < chartArea.top || y > chartArea.bottom) continue;
        ctx.fillStyle = color;
        ctx.fillText(text, chartArea.left + 4, y + dy);
      }
      ctx.restore();
    },
  };

  new Chart(document.getElementById('capacityChart'), {
    type: 'bar',
    plugins: [inlineRateLabels],
    data: {
      labels: ac.years,
      datasets: [
        { type: 'bar',  label: 'דו-שימוש',          data: ac.dualuse,      backgroundColor: '#378ADD', stack: 's', borderRadius: 2 },
        { type: 'bar',  label: 'מתקנים קרקעיים',    data: ac.landsystems,  backgroundColor: '#BA7517', stack: 's', borderRadius: 2 },
        { type: 'bar',  label: 'אגרו-וולטאי',       data: ac.agrovoltaics, backgroundColor: '#639922', stack: 's', borderRadius: 2 },
        { type: 'bar',  label: 'טכנולוגיות נוספות', data: ac.technologies, backgroundColor: '#D4537E', stack: 's', borderRadius: 2 },
        {
          type: 'line', label: '_currentRate',
          data: flatLine(ac.currentRate),
          borderColor: mutedColor, borderDash: [5, 4], borderWidth: 1.5,
          pointRadius: 0, fill: false,
        },
        {
          type: 'line', label: '_requiredRate',
          data: flatLine(ac.requiredRate),
          borderColor: '#D85A30', borderDash: [5, 4], borderWidth: 1.5,
          pointRadius: 0, fill: false,
        },
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          ...baseLegend,
          labels: {
            ...baseLegend.labels,
            filter: (item) => !item.text.startsWith('_'),
          },
        },
        tooltip: {
          rtl: true,
          filter: (item) => !item.dataset.label.startsWith('_'),
          callbacks: { label: (c) => ` ${c.dataset.label}: ${c.parsed.y?.toFixed(2)} GW` },
        },
      },
      scales: {
        x: { ...baseScales.x, stacked: true },
        y: {
          ...baseScales.y, stacked: true,
          ticks: { ...baseScales.y.ticks, callback: (v) => v.toFixed(1) + ' GW' },
        },
      },
    },
  });
  /* ── Detail capacity chart (2015–2035, 10 bars/year) ── */
  const YEARS_ALL = Array.from({ length: 21 }, (_, i) => 2015 + i);
  const BPY  = 10;   // bars per year
  const HIST = 2025; // last historical year
  const fa   = ac.futureAnnual;

  // 210-element array: BPY identical values per year, null for irrelevant years
  function mkBars(annualArr, futureRate, isPastDataset) {
    return YEARS_ALL.flatMap((year, yi) => {
      const yearIsPast = year <= HIST;
      if (isPastDataset !== yearIsPast) return Array(BPY).fill(null);
      const annual = yearIsPast ? (annualArr[yi] ?? 0) : futureRate;
      return Array(BPY).fill(annual / BPY);
    });
  }

  // Plugin: draw year labels centered under each year's group of BPY bars
  const yearLabelPlugin = {
    id: 'yearLabels',
    afterDraw(chart) {
      const { ctx, chartArea, scales: { x } } = chart;
      if (!chartArea) return;
      ctx.save();
      ctx.fillStyle  = textColor;
      ctx.font       = '10px Heebo, Arial, sans-serif';
      ctx.textAlign  = 'center';
      ctx.textBaseline = 'top';
      YEARS_ALL.forEach((year, i) => {
        const x1 = x.getPixelForValue(i * BPY);
        const x2 = x.getPixelForValue(i * BPY + BPY - 1);
        ctx.fillText(String(year), (x1 + x2) / 2, chartArea.bottom + 4);
      });
      ctx.restore();
    },
  };

  new Chart(document.getElementById('detailCapacityChart'), {
    type: 'bar',
    plugins: [yearLabelPlugin],
    data: {
      labels: Array.from({ length: YEARS_ALL.length * BPY }, (_, i) => i),
      datasets: [
        // Historical — solid (2015–2025)
        { label: 'דו-שימוש',          data: mkBars(ac.dualuse,      0, true),  backgroundColor: '#378ADD', stack: 's', barPercentage: 1.0, categoryPercentage: 1.0 },
        { label: 'מתקנים קרקעיים',    data: mkBars(ac.landsystems,  0, true),  backgroundColor: '#BA7517', stack: 's', barPercentage: 1.0, categoryPercentage: 1.0 },
        { label: 'אגרו-וולטאי',       data: mkBars(ac.agrovoltaics, 0, true),  backgroundColor: '#639922', stack: 's', barPercentage: 1.0, categoryPercentage: 1.0 },
        { label: 'טכנולוגיות נוספות', data: mkBars(ac.technologies, 0, true),  backgroundColor: '#D4537E', stack: 's', barPercentage: 1.0, categoryPercentage: 1.0 },
        // Future — light fill + top border (2026–2035)
        { label: '_f-du', data: mkBars(null, fa.dualuse,      false), backgroundColor: 'rgba(55,138,221,0.18)',  borderColor: '#378ADD', borderWidth: { top:1,right:0,bottom:0,left:0 }, stack: 's', barPercentage: 1.0, categoryPercentage: 1.0 },
        { label: '_f-ls', data: mkBars(null, fa.landsystems,  false), backgroundColor: 'rgba(186,117,23,0.18)',  borderColor: '#BA7517', borderWidth: { top:1,right:0,bottom:0,left:0 }, stack: 's', barPercentage: 1.0, categoryPercentage: 1.0 },
        { label: '_f-ag', data: mkBars(null, fa.agrovoltaics, false), backgroundColor: 'rgba(99,153,34,0.18)',   borderColor: '#639922', borderWidth: { top:1,right:0,bottom:0,left:0 }, stack: 's', barPercentage: 1.0, categoryPercentage: 1.0 },
        { label: '_f-tc', data: mkBars(null, fa.technologies, false), backgroundColor: 'rgba(212,83,126,0.18)',  borderColor: '#D4537E', borderWidth: { top:1,right:0,bottom:0,left:0 }, stack: 's', barPercentage: 1.0, categoryPercentage: 1.0 },
      ],
    },
    options: {
      responsive: true,
      aspectRatio: 1.5,
      animation: false,
      layout: { padding: { bottom: 18 } },
      plugins: {
        legend: {
          ...baseLegend,
          labels: { ...baseLegend.labels, filter: (item) => !item.text.startsWith('_') },
        },
        tooltip: {
          rtl: true,
          filter: (item) => !item.dataset.label.startsWith('_'),
          callbacks: {
            title: (items) => String(YEARS_ALL[Math.floor(items[0].dataIndex / BPY)]),
            label: (c) => ` ${c.dataset.label}: ${(c.parsed.y * BPY).toFixed(2)} GW/שנה`,
          },
        },
      },
      scales: {
        x: {
          stacked: true,
          ticks:  { display: false },
          grid:   { display: false },
          border: { display: false },
        },
        y: {
          stacked: true,
          beginAtZero: true,
          grid: { color: gridColor },
          ticks: { color: textColor, font: { size: 10 }, callback: (v) => v.toFixed(1) + ' GW' },
        },
      },
    },
  });
})();

const toggle = document.getElementById('sidebarToggle');
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebarOverlay');
  toggle.addEventListener('click', () => {
    sidebar.classList.toggle('open');
    overlay.classList.toggle('open');
  });
  overlay.addEventListener('click', () => {
    sidebar.classList.remove('open');
    overlay.classList.remove('open');
  });
</script>
</body>
</html>
