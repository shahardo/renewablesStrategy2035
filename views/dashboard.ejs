<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>לוח מעקב — אנרגיות מתחדשות 2035</title>
  <link rel="stylesheet" href="/dashboard-styles.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
</head>
<body>

<div class="layout">
  <%- include('partials/sidebar') %>

  <main class="main-content">
    <div class="top-bar">
      <button class="theme-toggle" id="themeToggle" aria-label="החלף מצב תאורה">
        <i class="ti ti-sun" id="themeIcon"></i>
      </button>
      <button class="sidebar-toggle" id="sidebarToggle" aria-label="פתח תפריט">
        <i class="ti ti-menu-2"></i>
      </button>
    </div>
    <div class="db">
      <h2 class="sr-only">לוח מעקב יישום תוכנית אנרגיות מתחדשות 2035 — KPIs ומדדי התקדמות לפי 6 מהלכי-על</h2>

      <div class="kgrid">
        <% kpis.forEach(kpi => { %>
        <div class="kcard">
          <div class="klabel"><%- kpi.label %></div>
          <div class="kval"><%- kpi.value %></div>
          <div class="ksub"><%- kpi.sub %></div>
          <% if (kpi.progress != null) { %>
          <div class="kpbar"><div class="kpfill" style="width:<%= kpi.progress %>%;background:<%= kpi.color %>"></div></div>
          <% } %>
        </div>
        <% }) %>
      </div>

      <div class="chart-grid">
        <div class="chart-panel">
          <div class="sec-hdr">מפת הדרכים: עבר ← הווה ← עתיד (2015–2035)</div>
          <canvas id="trajectoryChart"></canvas>
        </div>
        <div class="chart-panel">
          <div class="sec-hdr">קיבולת שנתית מותקנת לפי סוג (GW)</div>
          <canvas id="capacityChart"></canvas>
        </div>
      </div>

      <div class="cap-layout">
        <div class="panel">
          <div class="sec-hdr">מסלול קיבולת לעמידה ביעד 26 GW ב-2035</div>

          <% capacityTracks.forEach(track => { %>
          <div class="caprow">
            <div class="caplabel"><%- track.label %></div>
            <div class="captrack">
              <% track.fills.forEach(fill => { %>
              <div class="capfill" style="left:<%= fill.left %>%;width:<%= fill.width %>%;background:<%= fill.color %>"></div>
              <% }) %>
              <div class="captarget" style="left:<%= track.target %>%"></div>
            </div>
            <div class="capval"><%- track.capval %></div>
          </div>
          <% }) %>

          <div class="leg">
            <div class="legitem"><div class="legsq" style="background:#639922"></div>מותקן</div>
            <div class="legitem"><div class="legsq" style="background:#9FE1CB"></div>בהקמה</div>
            <div class="legitem"><div class="legsq" style="background:var(--color-background-secondary)"></div>נדרש נוסף</div>
            <div class="legitem"><div class="leg-target"></div>יעד 2035</div>
          </div>
        </div>

        <div class="chart-panel">
          <div class="sec-hdr">קיבולת מותקנת מצטברת לפי סוג (GW) — 2015–2035</div>
          <canvas id="detailCapacityChart"></canvas>
        </div>
      </div>

      <div class="sec-hdr">6 מהלכי-על — לחץ לפרטים ולמעקב מעמיק</div>
      <div class="igrid">
        <% const dotColors = { done: '#639922', progress: '#378ADD', early: '#BA7517', none: 'var(--color-border-tertiary)' }; %>
        <% initiatives.forEach(init => { %>
        <a class="icard" href="/initiative/<%= init.id %>">
          <div class="ihead">
            <div class="iico" style="background:<%= init.iconBg %>">
              <i class="ti <%= init.icon %>" style="color:<%= init.iconColor %>" aria-hidden="true"></i>
            </div>
            <div class="ititle"><%- init.title %></div>
          </div>
          <div class="isub"><%- init.subtitle %></div>
          <% if (init.type === 'gw') { %>
          <div class="igw"><%- init.gwCurrent %> <span>/ <%- init.gwTarget %> GW</span></div>
          <% } else { %>
          <div class="icard-infra">תשתית מאפשרת</div>
          <% } %>
          <div class="icard-pbar">
            <div class="icard-ptrack">
              <div class="icard-pfill" style="width:<%= init.avgPct %>%;background:<%= init.color %>"></div>
            </div>
            <div class="icard-pval"><%= init.avgPct %>%</div>
          </div>
          <div class="icard-dots">
            <% init.actions.forEach(action => { %>
            <div class="icard-dot" style="background:<%= dotColors[action.status] %>"></div>
            <% }) %>
          </div>
          <div class="icard-count"><%= init.actions.length %> צעדי מדיניות</div>
        </a>
        <% }) %>
      </div>

    </div>
  </main>
</div>

<script>
function initCharts() {
  if (typeof Chart === 'undefined') {
    setTimeout(initCharts, 50);
    return;
  }

  (function () {
    const dark      = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const textColor = dark ? '#a8a7a2' : '#5f5e5a';
    const mutedColor= dark ? '#6a6966' : '#9d9c98';
    const gridColor = dark ? 'rgba(240,239,233,0.07)' : 'rgba(26,26,24,0.05)';

    const cd = <%- JSON.stringify(charts) %>;

  const baseScales = {
    x: { ticks: { color: textColor, font: { size: 10 } }, grid: { color: gridColor } },
    y: { ticks: { color: textColor, font: { size: 10 } }, grid: { color: gridColor }, beginAtZero: true }
  };
  const baseLegend = { rtl: true, position: 'bottom', labels: { color: textColor, font: { size: 11 }, boxWidth: 18, padding: 10 } };

  /* ── Trajectory chart ──────────────────────────── */
  const currentIdx = cd.trajectory.years.indexOf(cd.trajectory.currentYear);

  new Chart(document.getElementById('trajectoryChart'), {
    type: 'line',
    data: {
      labels: cd.trajectory.years,
      datasets: [
        {
          label: 'מגמה היסטורית',
          data: cd.trajectory.historical,
          borderColor: '#4A90D9',
          backgroundColor: 'rgba(74,144,217,0.08)',
          borderWidth: 2.5,
          pointRadius: (ctx) => ctx.dataIndex === currentIdx ? 6 : 2,
          pointBackgroundColor: '#4A90D9',
          fill: true, tension: 0.4, spanGaps: false,
        },
        {
          label: `תוכנית מואצת (${cd.trajectory.targetEnd}%)`,
          data: cd.trajectory.target,
          borderColor: '#639922',
          backgroundColor: 'rgba(99,153,34,0.07)',
          borderWidth: 2,
          pointRadius: (ctx) => ctx.dataIndex === cd.trajectory.years.length - 1 ? 5 : 0,
          pointBackgroundColor: '#639922',
          fill: true, tension: 0.35, spanGaps: false,
        },
        {
          label: `המשך המגמה הנוכחית (${cd.trajectory.trendEnd}%)`,
          data: cd.trajectory.trend,
          borderColor: '#D85A30',
          borderDash: [6, 4],
          borderWidth: 2,
          pointRadius: (ctx) => ctx.dataIndex === cd.trajectory.years.length - 1 ? 5 : 0,
          pointBackgroundColor: '#D85A30',
          fill: false, tension: 0.3, spanGaps: false,
        },
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: { ...baseLegend },
        tooltip: { rtl: true, callbacks: { label: (c) => ` ${c.dataset.label}: ${c.parsed.y}%` } },
      },
      scales: {
        x: { ...baseScales.x },
        y: {
          ...baseScales.y,
          max: 50,
          ticks: { ...baseScales.y.ticks, callback: (v) => v + '%' },
        },
      },
    },
  });

  /* ── Annual capacity chart ─────────────────────── */
  const ac = cd.annualCapacity;
  const flatLine = (val) => ac.years.map((_, i) => (i >= currentIdx ? val : null));

  const inlineRateLabels = {
    id: 'inlineRateLabels',
    afterDatasetsDraw(chart) {
      const { ctx, chartArea, scales } = chart;
      if (!chartArea) return;
      const lines = [
        { value: ac.currentRate,  text: `${ac.currentRate} GW/שנה — קצב נוכחי`,  color: mutedColor, dy: -5 },
        { value: ac.requiredRate, text: `${ac.requiredRate} GW/שנה — קצב נדרש`, color: '#D85A30',  dy: -5 },
      ];
      ctx.save();
      ctx.font = 'bold 9.5px Heebo, Arial, sans-serif';
      ctx.textAlign = 'left';
      for (const { value, text, color, dy } of lines) {
        const y = scales.y.getPixelForValue(value);
        if (y < chartArea.top || y > chartArea.bottom) continue;
        ctx.fillStyle = color;
        ctx.fillText(text, chartArea.left + 4, y + dy);
      }
      ctx.restore();
    },
  };

  new Chart(document.getElementById('capacityChart'), {
    type: 'bar',
    plugins: [inlineRateLabels],
    data: {
      labels: ac.years,
      datasets: [
        { type: 'bar',  label: 'דו-שימוש',          data: ac.dualuse,           backgroundColor: '#378ADD', stack: 's', borderRadius: 2 },
        { type: 'bar',  label: 'מתקנים קרקעיים',    data: ac.landsystems,       backgroundColor: '#BA7517', stack: 's', borderRadius: 2 },
        { type: 'bar',  label: 'אגרו-וולטאי',       data: ac.agrovoltaics,      backgroundColor: '#639922', stack: 's', borderRadius: 2 },
        { type: 'bar',  label: 'טכנולוגיות נוספות', data: ac.technologies,      backgroundColor: '#D4537E', stack: 's', borderRadius: 2 },
        { type: 'bar',  label: '_future_dualuse',    data: ac.future_dualuse,    backgroundColor: 'rgba(55, 138, 221, 0.25)', stack: 'future', borderRadius: 2 },
        { type: 'bar',  label: '_future_landsystems',data: ac.future_landsystems,backgroundColor: 'rgba(186, 117, 23, 0.25)', stack: 'future', borderRadius: 2 },
        { type: 'bar',  label: '_future_agrovoltaics',data: ac.future_agrovoltaics,backgroundColor: 'rgba(99, 153, 34, 0.25)', stack: 'future', borderRadius: 2 },
        { type: 'bar',  label: '_future_technologies', data: ac.future_technologies, backgroundColor: 'rgba(212, 83, 126, 0.25)', stack: 'future', borderRadius: 2 },
        {
          type: 'line', label: '_currentRate',
          data: flatLine(ac.currentRate),
          borderColor: mutedColor, borderDash: [5, 4], borderWidth: 1.5,
          pointRadius: 0, fill: false,
        },
        {
          type: 'line', label: '_requiredRate',
          data: flatLine(ac.requiredRate),
          borderColor: '#D85A30', borderWidth: 2.5, borderDash: [4, 3],
          pointRadius: 0, fill: false,
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          ...baseLegend,
          labels: { ...baseLegend.labels, filter: (item) => !item.text.startsWith('_') },
        },
        tooltip: {
          rtl: true,
          filter: (item) => !item.dataset.label.startsWith('_'),
          callbacks: { label: (c) => ` ${c.dataset.label}: ${c.parsed.y?.toFixed(2)} GW` },
        },
      },
      scales: {
        x: { ...baseScales.x, stacked: true, maxRotation: 0, barPercentage: 0.95, categoryPercentage: 0.95 },
        y: {
          ...baseScales.y, stacked: true, max: 2.2,
          ticks: { ...baseScales.y.ticks, callback: (v) => v.toFixed(1) + ' GW' },
        },
      },
    },
  });
  /* ── Stacked bars: cumulative installed capacity 2015–2035 ── */
  const CUM_YEARS = ac.years;           // 21 years
  const BPY2      = 5;                  // bars per year → 21 × 5 = 105 bars
  const HIST_YR   = 2025;

  function cumInstalled(annual, futureRate) {
    let sum = 0;
    return CUM_YEARS.map((_, i) => {
      sum += (annual[i] != null) ? annual[i] : futureRate;
      return parseFloat(sum.toFixed(3));
    });
  }

  const cumDU = cumInstalled(ac.dualuse,      ac.futureAnnual.dualuse);
  const cumLS = cumInstalled(ac.landsystems,  ac.futureAnnual.landsystems);
  const cumAG = cumInstalled(ac.agrovoltaics, ac.futureAnnual.agrovoltaics);
  const cumTC = cumInstalled(ac.technologies, ac.futureAnnual.technologies);

  const installedCapacity = (ac.installedCapacity || {});

  // Build full per-bar arrays so each technology is a single dataset (avoids stacking-order flips)
  function mkCumBarsFull(cumArr) {
    return CUM_YEARS.flatMap((year, yi) => Array(BPY2).fill(cumArr[yi]));
  }

  function mkStyleArrays(techKey, cumArr, solidHex, lightHex) {
    const thresholdGw = installedCapacity[techKey] != null
      ? installedCapacity[techKey] / 1000
      : Number.POSITIVE_INFINITY;
    const bg = [];
    const border = [];
    const bwidth = [];
    for (let yi = 0; yi < CUM_YEARS.length; yi++) {
      const isSolid = cumArr[yi] <= thresholdGw;
      for (let i = 0; i < BPY2; i++) {
        bg.push(isSolid ? solidHex : lightHex);
        border.push(isSolid ? solidHex : lightHex);
        bwidth.push(isSolid ? 0 : 1);
      }
    }
    return { bg, border, bwidth };
  }

  const labels = Array.from({ length: CUM_YEARS.length * BPY2 }, (_, i) => i);

  const duStyles = mkStyleArrays('dualuse', cumDU, '#378ADD', '#A5CAF5');
  const lsStyles = mkStyleArrays('landsystems', cumLS, '#BA7517', '#E6CE9B');
  const agStyles = mkStyleArrays('agrovoltaics', cumAG, '#639922', '#B7DA96');
  const tcStyles = mkStyleArrays('technologies', cumTC, '#D4537E', '#F0BBCF');

  new Chart(document.getElementById('detailCapacityChart'), {
    type: 'bar',
    data: {
      labels,
      datasets: [
        { label: 'דו-שימוש',          data: mkCumBarsFull(cumDU), backgroundColor: duStyles.bg, borderColor: duStyles.border, borderWidth: duStyles.bwidth, stack: 's', barPercentage: 1.0, categoryPercentage: 0.6 },
        { label: 'מתקנים קרקעיים',    data: mkCumBarsFull(cumLS), backgroundColor: lsStyles.bg, borderColor: lsStyles.border, borderWidth: lsStyles.bwidth, stack: 's', barPercentage: 1.0, categoryPercentage: 0.6 },
        { label: 'אגרו-וולטאי',       data: mkCumBarsFull(cumAG), backgroundColor: agStyles.bg, borderColor: agStyles.border, borderWidth: agStyles.bwidth, stack: 's', barPercentage: 1.0, categoryPercentage: 0.6 },
        { label: 'טכנולוגיות נוספות', data: mkCumBarsFull(cumTC), backgroundColor: tcStyles.bg, borderColor: tcStyles.border, borderWidth: tcStyles.bwidth, stack: 's', barPercentage: 1.0, categoryPercentage: 0.6 },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      animation: false,
      plugins: {
        legend: { ...baseLegend },
        tooltip: {
          rtl: true,
          callbacks: {
            title:  (items) => String(CUM_YEARS[Math.floor(items[0].dataIndex / BPY2)]),
            label:  (c) => ` ${c.dataset.label}: ${c.parsed.y.toFixed(2)} GW`,
            footer: (items) => ` סה"כ: ${items.reduce((s, c) => s + c.parsed.y, 0).toFixed(1)} GW`,
          },
        },
      },
      scales: {
        x: {
          stacked: true,
          ticks: {
            color: textColor,
            font: { size: 10 },
            maxRotation: 0,
            autoSkip: false,
            callback: (_, idx) => idx % (BPY2*2) === Math.floor(BPY2 / 2)
              ? String(CUM_YEARS[Math.floor(idx / BPY2)])
              : null,
          },
          grid:   { display: false },
          border: { display: false },
        },
        y: {
          stacked: true,
          beginAtZero: true,
          max: 28,
          grid:  { color: gridColor },
          ticks: { color: textColor, font: { size: 10 }, callback: (v) => v.toFixed(0) + ' GW' },
        },
      },
    },
  });
  })();
}

initCharts();

const toggle = document.getElementById('sidebarToggle');
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebarOverlay');
  toggle.addEventListener('click', () => {
    sidebar.classList.toggle('open');
    overlay.classList.toggle('open');
  });
  overlay.addEventListener('click', () => {
    sidebar.classList.remove('open');
    overlay.classList.remove('open');
  });

  // Theme toggle with localStorage (default: light)
  const themeToggle = document.getElementById('themeToggle');
  const themeIcon = document.getElementById('themeIcon');
  const html = document.documentElement;
  
  function applyTheme(isDark) {
    if (isDark) {
      html.setAttribute('data-theme', 'dark');
      themeIcon.className = 'ti ti-moon';
      localStorage.setItem('theme', 'dark');
    } else {
      html.removeAttribute('data-theme');
      themeIcon.className = 'ti ti-sun';
      localStorage.setItem('theme', 'light');
    }
  }
  
  function initTheme() {
    const saved = localStorage.getItem('theme');
    const isDark = saved === 'dark';
    applyTheme(isDark);
  }
  
  themeToggle.addEventListener('click', () => {
    const isDark = html.hasAttribute('data-theme');
    applyTheme(!isDark);
  });
  
  initTheme();
</script>
</body>
</html>
